# Rank AI - Frontend Configuration (Next.js)

# [REQUIRED] The base URL for the Rank AI Backend API
# For local development: http://localhost:8000/api
# For production: https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# [REQUIRED] Firebase Configuration
# These are PUBLIC variables used by the browser.
# DO NOT include any secret keys (like GENAI_API_KEY) here.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
