# Rank AI - Backend Configuration
# ---------------------------------------------------------
# CAUTION: Never commit your real .env file or share these keys.
# ---------------------------------------------------------

# [REQUIRED] Google Cloud Project Settings
GCP_PROJECT_ID=your-project-id
GCS_BUCKET_NAME=your-bucket-name
VERTEX_LOCATION=us-central1
PORT=8000

# [REQUIRED] Google Gemini API Key
# For Generative AI features. Keep this server-side ONLY.
# Obtain from: https://aistudio.google.com/
GENAI_API_KEY=your-gemini-api-key

# [REQUIRED] Google Cloud Service Account
# For Firestore, Storage, etc.
# These individual fields are used if service-account.json is not used.
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_TYPE=service_account
GOOGLE_CLOUD_PRIVATE_KEY_ID=your-key-id
GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CLOUD_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLOUD_CLIENT_ID=your-client-id
GOOGLE_CLOUD_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_CLOUD_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_CLOUD_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs

# [OPTIONAL] Allowed origins for CORS (Default: http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000
